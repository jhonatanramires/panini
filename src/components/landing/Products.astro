---
import { Image } from "astro:assets";
import p1 from "@/images/caja104.jpeg";
import p2 from "@/images/caja52.jpeg";
import p3 from "@/images/AlbumAzul.jpeg";
//import p5 from "@/images/5.jpeg";
//import p6 from "@/images/6.jpeg";
const products = [
  {
    url: "https://wa.me/571341241?text=Estoy%20interesado%20en%20comprar%20la%20caja%20de%20104%20sobres",
    title: "",
    subtitle: "Caja de 104 sobres",
    price: "$450.000",
    image: p1,
  },
  {
    url: "https://wa.me/571341241?text=Estoy%20interesado%20en%20comprar%20la%20media%20caja%20de%2052%20sobres",
    title: "",
    subtitle: "Media caja de 52 sobres",
    price: "$225.000",
    image: p2,
  },
  {
    url: "https://wa.me/571341241?text=Estoy%20interesado%20en%20comprar%20el%20%C3%A1lbum%20pasta%20dura%20azul",
    title: "Álbum pasta dura azul",
    subtitle: " ",
    price: "$59.000",
    image: p3,
  },
  {
    url: "https://wa.me/571341241?text=Estoy%20interesado%20en%20comprar%20el%20%C3%A1lbum%20pasta%20dura%20gold",
    title: "Álbum pasta dura gold",
    subtitle: " ",
    price: "$90.000",
    image: p3,
  },
  // {
  //   url: "#_",
  //   title: "Modular Synth Box",
  //   subtitle: "Magnetic knobs, dual input",
  //   price: "$149",
  //   image: p5,
  // },
  // {
  //   url: "#_",
  //   title: "Compact Action Camera",
  //   subtitle: "Transparent shell, neon ring",
  //   price: "$189",
  //   image: p6,
  // },
];
---

<section>
  <div
    class="grid grid-cols-1 gap-6 lg:gap-y-24 md:grid-cols-2 lg:grid-cols-3 py-12"
  >
    {
      products.map((product) => (
        <figure class="relative ">
          <a href={product.url} aria-hidden="true" class="absolute inset-0" />
          <Image
            width="800"
            height="800"
            alt={product.title}
            src={product.image}
            class="w-full rounded-3xl shadow aspect-12/9 object-cover object-center"
          />
          <div class="mt-2 flex justify-between px-6">
            <div>
              <p class="mt-1 text-sm font-medium  text-base-900">
                {product.subtitle}
              </p>
              <h3 class="text-xs text-base-500">{product.title}</h3>
            </div>
            <p class="text-base text-orange-600">{product.price}</p>
          </div>
        </figure>
      ))
    }
  </div>
</section>
